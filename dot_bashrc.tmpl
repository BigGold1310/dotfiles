# PATH
if ! [[ "${PATH}" =~ "${HOME}/.local/bin:${HOME}/bin:" ]]; then
    PATH="${HOME}/.local/bin:${HOME}/bin:${PATH}"
fi

# aqua
export AQUA_ROOT_DIR="${HOME}/.local/share/aquaproj-aqua"
export AQUA_GLOBAL_CONFIG="${HOME}/.config/aquaproj-aqua/aqua.yaml"
if ! [[ "${PATH}" =~ "${AQUA_ROOT_DIR}/bin" ]]; then
    PATH="${AQUA_ROOT_DIR}/bin:${PATH}"
fi

export PATH

{{- if not .codespaces }}
# SSH agent socket (1Password)
{{ if eq .chezmoi.os "linux" -}}
export SSH_AUTH_SOCK="${HOME}/.1password/agent.sock"
{{- else if eq .chezmoi.os "darwin" -}}
export SSH_AUTH_SOCK="${HOME}/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- end }}
{{- end }}

# Go
export GOPATH=~/.cache/go

# History
HISTFILE=~/.bash_history
HISTSIZE=10000
HISTFILESIZE=10000
HISTCONTROL=ignoredups:ignorespace
shopt -s histappend

# Completion — must load before kubectl completion
if [[ -r "/opt/homebrew/etc/profile.d/bash_completion.sh" ]]; then
    source "/opt/homebrew/etc/profile.d/bash_completion.sh"
elif [[ -r "/etc/bash_completion" ]]; then
    source "/etc/bash_completion"
fi

# fzf — Ctrl+R history, Ctrl+T file picker, Alt+C cd (requires fzf >= 0.48)
if command -v fzf >/dev/null; then
    eval "$(fzf --bash)"
fi

# Prompt
if command -v starship >/dev/null; then
    eval "$(starship init bash)"
fi

# Dev tools
command -v mise   >/dev/null && eval "$(mise activate bash --shims)"
command -v direnv >/dev/null && eval "$(direnv hook bash)"

# Kubernetes
if command -v kubectl >/dev/null; then
    source <(kubectl completion bash)
    alias kc="kubectl"
    if [ -d "${HOME}/.kube" ]; then
        mkdir -p "${HOME}/.kube/configs"
        export KUBECONFIG=~/.kube/config:$(find "${HOME}/.kube/configs/" -type f | tr '\n' ':')
    fi
fi

# aqua
if command -v aqua >/dev/null; then
    eval "$(aqua completion bash)"
fi

# Aliases
alias la="ls -la"
alias ll="ls -l"
